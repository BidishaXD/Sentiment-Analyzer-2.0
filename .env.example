# App
VITE_APP_NAME="Sentiment Analyzer 2.0"

# Local-only sentiment analysis
VITE_ENABLE_LOCAL_SENTIMENT=true

# Path for local model files if you later add them to /public/models
VITE_SENTIMENT_MODEL_PATH="/models/sentiment"

# Privacy defaults
VITE_STORE_RAW_MESSAGES_DEFAULT=false
VITE_AUTO_DELETE_IMPORTED_FILES=true

# Demo mode for client presentations
VITE_ENABLE_DEMO_DATA=true